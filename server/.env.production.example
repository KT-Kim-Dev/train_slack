# ===== 배포 서버 설정 예시 (192.168.155.89) =====
# 사용법: 이 파일을 .env.production 으로 복사 후 값을 채운다.
# 실행: npm run start:prod -w server

PORT=3000

JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

DB_PATH=./data/intra-chat.sqlite
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=104857600

CORS_ORIGIN=http://localhost:5173
ADMIN_USERNAMES=admin

# ===== v3: 업무 연동 (배포 서버 192.168.155.89) =====

# AI — Ollama 기본 포트 11434
OLLAMA_URL=http://192.168.155.89:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=60000
AI_CONTEXT_LIMIT=10

# Yona — 포트 확정 후 URL 주석 해제
# YONA_URL=http://192.168.155.89:<포트>
YONA_URL=
YONA_TOKEN=
YONA_DEFAULT_PROJECT=

# Jenkins — 포트 확정 후 URL 주석 해제
# JENKINS_URL=http://192.168.155.89:<포트>
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
