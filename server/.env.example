# 서버 설정 예시. 실제 사용 시 이 파일을 복사해 .env 로 만들고 값을 채운다.

# 서버가 바인딩할 포트 (명세: 예 3000)
PORT=3000

# JWT 서명 비밀키 (운영 배포 시 반드시 임의의 강한 값으로 교체)
JWT_SECRET=change-this-to-a-long-random-secret
# JWT 만료 기간
JWT_EXPIRES_IN=7d

# SQLite 데이터베이스 파일 경로
DB_PATH=./data/intra-chat.sqlite

# 업로드 파일 저장 경로 (운영: 공유폴더 경로 예 \\shared\intra-chat\uploads, 개발: 로컬 폴더)
UPLOAD_DIR=./uploads

# 1회 업로드 최대 파일 크기 (바이트, 기본 100MB)
MAX_FILE_SIZE=104857600

# CORS 허용 오리진 (개발 시 Vite 렌더러). 콤마로 여러 개 지정 가능
CORS_ORIGIN=http://localhost:5173

# 관리자 권한 아이디 (콤마 구분)
ADMIN_USERNAMES=admin

# ===== v3: 업무 연동 설정 (값이 비어 있으면 해당 기능 비활성화) =====

# --- AI 채팅 (로컬 Ollama, OpenAI 호환 API) ---
# 예: http://localhost:11434  (비우면 AI 기능 비활성화)
OLLAMA_URL=
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=60000
AI_CONTEXT_LIMIT=10
# AI 응답 언어: ko | en | auto
AI_REPLY_LANGUAGE=ko
# AI system 프롬프트에 추가할 지시사항
AI_EXTRA_INSTRUCTIONS=
# thinking 모델 추론 과정 표시 (true | false, 기본 false)
AI_SHOW_REASONING=false

# --- RAG 지식 베이스 ---
RAG_ENABLED=true
RAG_AUTO_LEARN=true
RAG_EMBEDDING_MODEL=nomic-embed-text
RAG_TOP_K=5
RAG_SHARED_FOLDER=

# --- Yona 이슈 관리 ---
# 예: http://yona.internal  (비우면 Yona 기능 비활성화)
YONA_URL=
YONA_TOKEN=
YONA_DEFAULT_PROJECT=

# --- Jenkins 빌드/CI ---
# 예: http://jenkins.internal  (비우면 Jenkins 기능 비활성화)
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
