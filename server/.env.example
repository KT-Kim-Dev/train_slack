# 서버 설정 예시.
# - 로컬 테스트: 이 파일을 .env 로 복사 (npm run server:dev)
# - 배포 서버(192.168.155.89): .env.production.example → .env.production (npm run start:prod)

# 서버가 바인딩할 포트 (명세: 예 3000)
PORT=3000

# JWT 서명 비밀키 (운영 배포 시 반드시 임의의 강한 값으로 교체)
JWT_SECRET=change-this-to-a-long-random-secret
# JWT 만료 기간
JWT_EXPIRES_IN=7d

# SQLite 데이터베이스 파일 경로
DB_PATH=./data/intra-chat.sqlite

# 업로드 파일 저장 경로 (운영: 공유폴더 경로 예 \\shared\intra-chat\uploads, 개발: 로컬 폴더)
UPLOAD_DIR=./uploads

# 1회 업로드 최대 파일 크기 (바이트, 기본 100MB)
MAX_FILE_SIZE=104857600

# CORS 허용 오리진 (개발 시 Vite 렌더러). 콤마로 여러 개 지정 가능
CORS_ORIGIN=http://localhost:5173

# 관리자 권한 아이디 (콤마 구분)
ADMIN_USERNAMES=admin

# ===== v3: 업무 연동 설정 (값이 비어 있으면 해당 기능 비활성화) =====

# --- AI 채팅 (로컬 Ollama, OpenAI 호환 API) ---
# 로컬 테스트: http://localhost:11434
# 배포 서버:   http://192.168.155.89:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT_MS=60000
AI_CONTEXT_LIMIT=10

# --- Yona 이슈 관리 (포트 확정 후 설정) ---
# 로컬: http://localhost:<포트>  /  배포: http://192.168.155.89:<포트>
YONA_URL=
YONA_TOKEN=
YONA_DEFAULT_PROJECT=

# --- Jenkins 빌드/CI (포트 확정 후 설정) ---
# 로컬: http://localhost:<포트>  /  배포: http://192.168.155.89:<포트>
JENKINS_URL=
JENKINS_USER=
JENKINS_TOKEN=
