{
  "name": "intra-chat",
  "version": "0.1.0",
  "private": true,
  "description": "사내 인트라넷용 Slack형 채팅 프로그램 (Intra-Chat) PoC",
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "server:dev": "npm run dev -w server",
    "server:create-user": "npm run create-user -w server",
    "client:dev": "npm run dev -w client",
    "client:build": "npm run build -w client",
    "dev": "echo '서버는 npm run server:dev, 클라이언트는 npm run client:dev 로 각각 실행하세요.'"
  },
  "engines": {
    "node": ">=18"
  }
}
